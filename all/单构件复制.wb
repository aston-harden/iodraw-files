637934,-0.25375588640001784],[-1.7309762411637934,7.091317885500044],[-11.160449557186148,7.19057199196719],[-11.210076610419677,-1.6433633571865958],[-4.907220936671245,-1.6433633571865958]]},{"id":"JMUiBhMBP1GXzLJb3lFBN","type":"text","x":2703.8877506034532,"y":504.44485259954604,"width":336,"height":315,"angle":0,"strokeColor":"#1f2532","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"strokeSharpness":"round","seed":1178266987,"version":971,"versionNonce":832738789,"isDeleted":false,"boundElements":null,"updated":1779259423259,"link":null,"text":"划线复制在产生后，目录树右侧抽屉按钮包括：\n删除、方位编辑、设置、复制、重命名\n【删除】删除当前划线复制对象\n【方位编辑】调整划线复制对象的整体位置，\nGizmo编辑过程中不会进行贴地计算，结束移动\n和参数窗口失焦后进行单构件贴地探测\n【设置】调整划线对象的参数，其弹出窗口如右\n此窗口打开时，路径矢量线和顶点也显示，可重\n调整矢量线；\n【复制】把这个划线对象作为一个单元进行复制\n这个弹出的复制窗口仅支持点击复制，每次点击\n复制产生一个划线复制对象，并自动加名称后缀\n后加入目录树。\n","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":310,"containerId":null,"originalText":"划线复制在产生后，目录树右侧抽屉按钮包括：\n删除、方位编辑、设置、复制、重命名\n【删除】删除当前划线复制对象\n【方位编辑】调整划线复制对象的整体位置，\nGizmo编辑过程中不会进行贴地计算，结束移动\n和参数窗口失焦后进行单构件贴地探测\n【设置】调整划线对象的参数，其弹出窗口如右\n此窗口打开时，路径矢量线和顶点也显示，可重\n调整矢量线；\n【复制】把这个划线对象作为一个单元进行复制\n这个弹出的复制窗口仅支持点击复制，每次点击\n复制产生一个划线复制对象，并自动加名称后缀\n后加入目录树。\n"},{"type":"rectangle","version":547,"versionNonce":535160555,"isDeleted":false,"id":"mh7F_i2QYuXLZy3NmAGis","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":3149.896940668928,"y":507.91808944191644,"strokeColor":"#000000","backgroundColor":"transparent","width":171,"height":191.5702597878195,"seed":889207621,"groupIds":["l-RoUDTsDLdhdTCoU4Va9"],"strokeSharpness":"sharp","boundElements":[],"updated":1779259423259,"link":null},{"type":"text","version":415,"versionNonce":654348613,"isDeleted":false,"id":"3MXIeSUxPY0MaP8lgVawc","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":3155.4341415966624,"y":513.9057020795229