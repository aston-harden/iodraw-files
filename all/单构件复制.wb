2,0],[-4.889958450276113,3.722163939183604],[-5.63439090491125,5.905834249855275],[-3.6492421352396556,5.608061934404538],[0.7180984861036624,1.38960747078657],[-0.8700205296336132,0]]},{"type":"line","version":667,"versionNonce":595947179,"isDeleted":false,"id":"buMGmy2fHHJqj-ZbQil1F","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":3339.944145615901,"y":612.9085909311445,"strokeColor":"#1f2532","backgroundColor":"transparent","width":9.479100369255884,"height":8.833935349153785,"seed":853373323,"groupIds":["8uNacg1lUy8IjwQwX9Xos"],"strokeSharpness":"sharp","boundElements":[],"updated":1779249215805,"link":null,"startBinding":null,"endBinding":null,"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":null,"points":[[-1.7309762411637934,-0.25375588640001784],[-1.7309762411637934,7.091317885500044],[-11.160449557186148,7.19057199196719],[-11.210076610419677,-1.6433633571865958],[-4.907220936671245,-1.6433633571865958]]},{"id":"JMUiBhMBP1GXzLJb3lFBN","type":"text","x":3460.7059879081407,"y":572.6266152948585,"width":336,"height":315,"angle":0,"strokeColor":"#1f2532","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"strokeSharpness":"round","seed":1178266987,"version":906,"versionNonce":2022131845,"isDeleted":false,"boundElements":null,"updated":1779250791748,"link":null,"text":"划线复制在产生后，目录树右侧抽屉按钮包括：\n删除、方位编辑、设置、复制、重命名\n【删除】删除当前划线复制对象\n【方位编辑】调整划线复制对象的整体位置，\nGizmo编辑过程中不会进行贴地计算，结束移动\n和参数窗口失焦后进行单构件贴地探测\n【设置】调整划线对象的参数，其弹出窗口如右\n此窗口打开时，路径矢量线和顶点也显示，可重\n调整矢量线；\n【复制】把这个划线对象作为一个单元进行复制\n这个弹出的复制窗口仅支持点击复制，每次点击\n复制产生一个划线复制对象，并自动加名称后缀\n后加入目录树。\n","fontSize":16,"fontFamily":2,"textAlign":"left","verticalAlign":"top","baseline":310,"containerId":null,"originalText":"划线复制在产生后，目录树右侧抽屉按钮包括：\n删除、方位编辑、设置、复制、重命名\n【删除】删除当前划线复制对象\n【方位编辑】调整划线复制对象的整体位置，\nGizmo编辑过程中不会进行贴地计算，结束移动\n和参数窗口失焦后进行单构件贴地探测\n【设置】调整划线对象的参数，其弹出窗口如右\n此窗口打开时，路径矢量线和顶点也显示，可重\n调整矢量线；\n【复制】把这个划线对象作为一个单元进行复制\n这个弹出的复制窗口仅支持点击复制，每次点击\n复制产生一个划线复制对象，并自动加名称后缀\n后加入目录树。\n"},{"type":"rectangle","version":482,"versionNonce":1984008421,"isDeleted":false,"id":"mh7F_i2QYuXLZy3NmAGis","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":3906.7151779736155,"y":576.0998521372289,"strokeColor":"#000000","backgroundColor":"transparent","width":171,"height":191.5702597878195,"seed":889207621,"groupIds":["l-RoUDTsDLdhdTCoU4Va9"],"strokeSharpness":"sharp","boundElements":[],"updated":1779250120179,"link":null},{"type":"text","version":350,"versionNonce":889723883,"isDeleted":false,"id":"3MXIeSUxPY0MaP8lgVawc","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":3912.25237890135,"y":582.0874647748354,"strokeColor":"#000000","backgroundColor":"transparent","width":97,"height":25,"seed":1185400715,"groupIds":["l-RoUDTsDLdhdTCoU4Va9"],"strokeSharpness":"sharp","boundElements":[],"updated":1779250120179,"link":null,"fontSize":16,"fontFamily":1,"text":"划线复制参数","baseline":18,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"划线复制参数"},{"type":"line","version":335,"versionNonce":336079941,"isDeleted":false,"id":"WyycS4wCiPdz4O5HIX-km","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":1,"opacity":100,"angle":0,"x":3904.979673823225,"y":606.6783613812808,"strokeColor":"#000000","backgroundColor":"transparent","width":171.81817626953125,"height":0,"seed":776112805,"groupIds":["l-RoUDTsDLdhdTCoU4Va9"],"strokeSharpness":"round","boundElements":[],"updated":1779250120179,"link":null,"startBinding":null,"endBinding":null,"lastCommittedPoint":null,"startArrowhead":null,"endArrowhead":null,"points":[[0,0],[171.81817626953125,0]]},{"type":"text","version":476,"versionNonce":823355019,"isDeleted":false,"id":"pTvNbvoVeoTsEFqOi48Cs","fillStyle":"hachure","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"x":3931.9830217145736